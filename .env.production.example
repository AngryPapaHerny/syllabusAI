# ============================================================
# syllabusAI — 프로덕션 환경 변수 템플릿
# Vercel Dashboard > Project > Settings > Environment Variables 에 등록
# 이 파일은 예시용 — 실제 값은 Vercel/Supabase 대시보드에서 관리
# ============================================================

# ------------------------------------------------------------
# Supabase (프로덕션)
# Supabase 대시보드 > Settings > API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 서버 전용 — Vercel에서 "Sensitive" 환경 변수로 등록
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------------------------------------------------------------
# LLM 프로바이더 (프로덕션)
# Vercel에서 "Sensitive" 환경 변수로 등록
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy...

# ------------------------------------------------------------
# 코드 샌드박스 API (프로덕션)
# 자체 호스팅 Piston 또는 Judge0 권장
# ------------------------------------------------------------
SANDBOX_API_URL=https://your-sandbox.example.com/api/v2/piston
SANDBOX_API_KEY=your-sandbox-api-key

# ------------------------------------------------------------
# 워커 인증 시크릿
# Vercel 환경 변수 + Supabase Secrets 동일한 값 등록
# supabase secrets set WORKER_SECRET=<same-value>
# ------------------------------------------------------------
WORKER_SECRET=your-production-secret-64-chars-min

# ------------------------------------------------------------
# 앱 설정 (프로덕션)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# LLM 기본 프로바이더
DEFAULT_LLM_PROVIDER=anthropic
