# ============================================================
# syllabusAI 환경변수 템플릿
# .env.local 파일로 복사 후 실제 값 입력
# ============================================================

# ============================================================
# LLM 프로바이더
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...
GROQ_API_KEY=gsk_...

# ============================================================
# Supabase
# ============================================================
# Supabase 프로젝트 대시보드 > Settings > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# 코드 샌드박스 (현재 구현: Wandbox /api/compile.json)
# 공용 Piston(emkc.org)은 2026-02-15 whitelist 전용 전환으로 사용 불가
# ============================================================
# Wandbox 공개 API: https://wandbox.org (키 불필요)
# 자체 호스팅 시 동일한 Wandbox 호환 베이스 URL 지정
SANDBOX_API_URL=https://wandbox.org
SANDBOX_API_KEY=

# ============================================================
# 앱 설정
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# gen/worker 엔드포인트 인증 토큰 (미설정 시 SUPABASE_SERVICE_ROLE_KEY 사용)
WORKER_SECRET=

# 기본 LLM 프로바이더 (anthropic | openai | google)
DEFAULT_LLM_PROVIDER=anthropic
