# ============================================================
# syllabusAI — 로컬 개발 환경 변수
# 이 파일을 .env.local 로 복사 후 실제 값을 채우세요.
# .env.local 은 절대 Git에 커밋하지 마세요.
# ============================================================

# ------------------------------------------------------------
# Supabase
# supabase start 실행 후 출력되는 값 사용
# 프로덕션: Supabase 대시보드 > Settings > API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# 서버 전용 (Route Handler, Edge Function 워커)
# 절대 NEXT_PUBLIC_ 접두사 사용 금지
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ------------------------------------------------------------
# LLM 프로바이더
# 실제 API 키가 없으면 LLM 호출 테스트 불가
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# ------------------------------------------------------------
# 코드 샌드박스 API
# 격리 실행 서비스 (현재 구현: Wandbox /api/compile.json, 키 불필요)
# ------------------------------------------------------------
SANDBOX_API_URL=https://wandbox.org
SANDBOX_API_KEY=

# ------------------------------------------------------------
# 워커 인증 시크릿
# gen-worker Edge Function 호출 시 Authorization 헤더에 사용
# 생성: openssl rand -hex 32
# ------------------------------------------------------------
WORKER_SECRET=your-random-secret-here

# ------------------------------------------------------------
# 앱 설정
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LLM 기본 프로바이더 (anthropic | openai | google)
DEFAULT_LLM_PROVIDER=anthropic
